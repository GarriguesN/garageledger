# GarageLedger environment variables.
# Copy to .env and fill in. Never commit .env.

# --- Required: database ---
DB_PATH=/opt/garageledger/data/garageledger.db

# --- Required: uploads directory (attachments) ---
UPLOAD_DIR=/opt/garageledger/data/uploads

# --- Required: 32+ random chars (e.g. `openssl rand -hex 32`) ---
SESSION_SECRET=replace-with-32+-chars-of-random-data

# --- Required for backups: destination directory ---
# Must exist or be creatable by the user running backups (cron).
BACKUP_DIR=/var/backups/garageledger

# --- Optional: backup retention window in days (default 30) ---
# Backups older than this are pruned on each successful backup run.
BACKUP_RETENTION_DAYS=30
